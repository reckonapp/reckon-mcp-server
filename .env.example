# Reckon MCP Server — Environment Variables
#
# Copy this file to .dev.vars for local development.
# For production, set secrets via: wrangler secret put <KEY>

# Auth provider URL and publishable key (used for OAuth login)
AUTH_URL=
AUTH_PUBLISHABLE_KEY=

# Shared secret for authenticating internal API calls
MCP_METRICS_SECRET=

# Token for OpenAI app verification (optional)
# OPENAI_APPS_VERIFICATION_TOKEN=
